# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose — Environment Template
# Copy to .env at project root. Fill values before: docker compose up -d
# DATABASE_URL & REDIS_URL are auto-set by compose (postgres/redis services).
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Docker service; compose builds DATABASE_URL from these) ───────
POSTGRES_USER=uims
POSTGRES_PASSWORD=uims_secret
POSTGRES_DB=uims
POSTGRES_PORT=5432

# ── Redis (Docker service; compose sets REDIS_URL=redis://redis:6379) ──────────
REDIS_PORT=6379

# ── Auth (required) ───────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── CORS (required in production; comma-separated origins) ───────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend URLs (build-time; NEXT_PUBLIC_* embedded in Next.js build) ──────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:3001
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_VERSION=1

# ── App ports (host mapping) ──────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000

# ── Seed (initial admin; set RUN_SEED=1 to seed on backend first start) ────────
# RUN_SEED=1
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=Admin123!

# ── Cloudinary (idea attachments, export storage) ────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── SMTP / Brevo (notification emails) ─────────────────────────────────────────
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
