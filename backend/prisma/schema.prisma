// Prisma v7+ enterprise schema: UUID ids, createdAt/updatedAt on every table,
// fixed Role table, normalized relations, indexes and constraints.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique
  fullName      String?        @db.VarChar(255)
  phone         String?        @unique @db.VarChar(30)
  address       String?        @db.Text
  gender        String?        @db.VarChar(50)
  dateOfBirth   DateTime?      @db.Date
  passwordHash  String
  isActive      Boolean        @default(true)
  roleId        String         @db.Uuid
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  departmentId  String?        @db.Uuid
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  ideas         Idea[]
  ideaVotes     IdeaVote[]
  ideaComments  IdeaComment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([roleId])
  @@index([departmentId])
  @@index([createdAt])
}

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model AcademicYear {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  startDate            DateTime
  endDate              DateTime?
  isActive             Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ideaSubmissionCycles IdeaSubmissionCycle[]

  @@index([startDate])
  @@index([isActive])
}

model Category {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @unique
  ideas           Idea[]
  cycleCategories CycleCategory[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([name])
}

model Idea {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String               @db.VarChar(500)
  description     String?              @db.Text
  categoryId      String?              @db.Uuid
  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cycleId         String?              @db.Uuid
  cycle           IdeaSubmissionCycle? @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  submittedById   String?              @db.Uuid
  submittedBy     User?                @relation(fields: [submittedById], references: [id], onDelete: Restrict)
  isAnonymous     Boolean              @default(false)
  termsAcceptedAt DateTime?
  attachments     IdeaAttachment[]
  votes           IdeaVote[]
  comments        IdeaComment[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([categoryId])
  @@index([cycleId])
  @@index([submittedById])
}

model IdeaVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId    String   @db.Uuid
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
}

model IdeaComment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId      String   @db.Uuid
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  content     String   @db.Text
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([ideaId])
  @@index([userId])
}

model IdeaAttachment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId             String   @db.Uuid
  idea               Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @db.VarChar(255)
  secureUrl          String   @db.VarChar(1024)
  fileName           String   @db.VarChar(512)
  mimeType           String?  @db.VarChar(128)
  sizeBytes          Int?
  createdAt          DateTime @default(now())

  @@index([ideaId])
}

model IdeaSubmissionCycle {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId         String          @db.Uuid
  academicYear           AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  name                   String?         @db.VarChar(255)
  ideaSubmissionClosesAt DateTime
  interactionClosesAt    DateTime
  status                 String          @db.VarChar(20)
  cycleCategories        CycleCategory[]
  ideas                  Idea[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([academicYearId])
  @@index([status])
}

model CycleCategory {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId    String              @db.Uuid
  categoryId String              @db.Uuid
  cycle      IdeaSubmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([cycleId, categoryId])
  @@index([cycleId])
  @@index([categoryId])
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenId   String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}
