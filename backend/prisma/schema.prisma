// Prisma v7+ enterprise schema: UUID ids, createdAt/updatedAt on every table,
// fixed Role table, normalized relations, indexes and constraints.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String            @unique
  fullName         String?           @db.VarChar(255)
  phone            String?           @unique @db.VarChar(30)
  address          String?           @db.Text
  gender           String?           @db.VarChar(50)
  dateOfBirth      DateTime?         @db.Date
  passwordHash     String
  isActive         Boolean           @default(true)
  roleId           String            @db.Uuid
  role             Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  departmentId     String?           @db.Uuid
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  exportJobs          ExportJob[]
  ideas            Idea[]
  ideaVotes        IdeaVote[]
  ideaComments     IdeaComment[]
  ideaCommentReactions IdeaCommentReaction[]
  ideaViews        IdeaView[]
  notifications    Notification[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([roleId])
  @@index([departmentId])
  @@index([createdAt])
  @@map("users")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50)
  message   String   @db.Text
  link      String?  @db.VarChar(512)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("departments")
}

model AcademicYear {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  startDate            DateTime
  endDate              DateTime?
  isActive             Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ideaSubmissionCycles IdeaSubmissionCycle[]

  @@index([startDate])
  @@index([isActive])
  @@map("academic_years")
}

model Category {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @unique
  ideas           Idea[]
  cycleCategories CycleCategory[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([name])
  @@map("categories")
}

model Idea {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String               @db.VarChar(500)
  description     String?              @db.Text
  categoryId      String?              @db.Uuid
  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cycleId         String?              @db.Uuid
  cycle           IdeaSubmissionCycle? @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  submittedById   String?              @db.Uuid
  submittedBy     User?                @relation(fields: [submittedById], references: [id], onDelete: Restrict)
  isAnonymous     Boolean              @default(false)
  termsAcceptedAt DateTime?
  attachments     IdeaAttachment[]
  votes           IdeaVote[]
  comments        IdeaComment[]
  views           IdeaView[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([categoryId])
  @@index([cycleId])
  @@index([submittedById])
  @@map("ideas")
}

model IdeaVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId    String   @db.Uuid
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
  @@map("idea_votes")
}

model IdeaComment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId          String            @db.Uuid
  idea            Idea              @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId          String            @db.Uuid
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  parentCommentId String?           @db.Uuid
  parentComment   IdeaComment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         IdeaComment[]     @relation("CommentReplies")
  content         String            @db.Text
  isAnonymous     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reactions IdeaCommentReaction[]

  @@index([ideaId])
  @@index([userId])
  @@index([parentCommentId])
  @@map("idea_comments")
}

model IdeaCommentReaction {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String      @db.Uuid
  comment   IdeaComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String      @db.Uuid
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String      @default("up") @db.VarChar(10)
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("idea_comment_reactions")
}

model IdeaAttachment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId             String   @db.Uuid
  idea               Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @db.VarChar(255)
  secureUrl          String   @db.VarChar(1024)
  fileName           String   @db.VarChar(512)
  mimeType           String?  @db.VarChar(128)
  sizeBytes          Int?
  createdAt          DateTime @default(now())

  @@index([ideaId])
  @@map("idea_attachments")
}

model IdeaSubmissionCycle {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId         String          @db.Uuid
  academicYear           AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  name                   String?         @db.VarChar(255)
  ideaSubmissionClosesAt DateTime
  interactionClosesAt    DateTime
  status                 String          @db.VarChar(20)
  isLocked               Boolean         @default(false)
  wasEverClosed          Boolean         @default(false)
  cycleCategories        CycleCategory[]
  exportJobs             ExportJob[]
  ideas                  Idea[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([academicYearId])
  @@index([status])
  @@map("idea_submission_cycles")
}

model CycleCategory {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId    String              @db.Uuid
  categoryId String              @db.Uuid
  cycle      IdeaSubmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([cycleId, categoryId])
  @@index([cycleId])
  @@index([categoryId])
  @@map("cycle_categories")
}

model IdeaView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ideaId    String   @db.Uuid
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([ideaId])
  @@index([userId])
  @@index([ideaId, userId, createdAt])
  @@map("idea_views")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenId   String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model ExportJob {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String              @db.Uuid
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleId       String              @db.Uuid
  cycle         IdeaSubmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  type          String              @db.VarChar(20)
  status        String              @db.VarChar(20)
  progress      Int                 @default(0)
  cloudinaryUrl String?             @db.VarChar(1024)
  fileName      String?             @db.VarChar(512)
  error         String?             @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([cycleId])
  @@index([status])
  @@index([status, createdAt])
  @@map("export_jobs")
}
