{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@generated/prisma$": "<rootDir>/mocks/prisma-client.ts",
    ".*generated/prisma/client.*": "<rootDir>/mocks/prisma-client.ts"
  }
}
