<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>New idea – Review required</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
</head>
<body style="margin:0;padding:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background:#f5f5f7;line-height:1.6;color:#1a1a1a;-webkit-font-smoothing:antialiased;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f5f7;padding:48px 24px;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.04),0 1px 2px rgba(0,0,0,0.06);">
          <tr>
            <td style="height:4px;background:linear-gradient(90deg,#1a1a1a 0%,#404040 100%);font-size:0;line-height:0;">&nbsp;</td>
          </tr>
          <tr>
            <td style="padding:40px 40px 36px;">
              <p style="margin:0 0 6px;font-size:11px;font-weight:600;color:#8e8e93;letter-spacing:0.08em;text-transform:uppercase;">Review required</p>
              <h1 style="margin:0 0 24px;font-size:22px;font-weight:600;color:#1a1a1a;letter-spacing:-0.02em;line-height:1.3;">New idea submitted</h1>
              <p style="margin:0 0 24px;font-size:15px;color:#525252;line-height:1.6;">A new idea has been submitted and needs your review.</p>
              <div style="background:#f5f5f7;border-radius:12px;padding:20px 24px;margin:0 0 28px;border:1px solid #e5e5ea;">
                <p style="margin:0 0 8px;color:#8e8e93;font-size:12px;font-weight:500;">Idea</p>
                <p style="margin:0 0 12px;color:#1a1a1a;font-size:15px;font-weight:500;">{{ideaTitle}}</p>
                <p style="margin:0 0 4px;color:#8e8e93;font-size:13px;">Submitted by {{#if isAnonymous}}Anonymous{{else}}{{submitterDisplayName}}{{#if submitterEmail}} <span style="color:#a1a1a6;">{{submitterEmail}}</span>{{/if}}{{/if}}</p>
                {{#if departmentName}}
                <p style="margin:8px 0 0;color:#8e8e93;font-size:13px;">{{departmentName}}</p>
                {{/if}}
              </div>
              {{#if hasAttachments}}
              <p style="margin:0 0 8px;font-size:13px;font-weight:500;color:#525252;">Attachments</p>
              <ul style="margin:0 0 24px;padding:0;list-style:none;">
                {{#each attachmentLinks}}
                <li style="margin:4px 0;"><a href="{{secureUrl}}" style="color:#1a1a1a;text-decoration:none;font-size:14px;font-weight:500;" target="_blank" rel="noopener">{{fileName}}</a></li>
                {{/each}}
              </ul>
              {{/if}}
              <a href="{{ideaLink}}" target="_blank" rel="noopener noreferrer" style="display:inline-block;padding:12px 24px;background:#1a1a1a;color:#ffffff !important;font-size:14px;font-weight:500;text-decoration:none;border-radius:10px;">View idea & review</a>
            </td>
          </tr>
          <tr>
            <td style="padding:0 40px 32px;">
              <p style="margin:0;color:#a1a1a6;font-size:12px;">Greenwich University · Idea Management System</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
